rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: logs
    // Fields:
    //   - id: string (required)
    //   - timestamp: string (required, ISO 8601)
    //   - method: string (required)
    //   - path: string (required)
    //   - ip: string (required)
    //   - userAgent: string (optional)
    //   - payload: map (optional)
    //   - threatLevel: string (required, enum: low, medium, high, critical)
    //   - threatType: string (optional)
    //   - analysis: string (required)
    //
    // Collection: stats
    // Document: current
    // Fields:
    //   - totalRequests: integer
    //   - threatsDetected: integer
    //   - criticalAlerts: integer
    //   - lastUpdated: string
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "jaibunk595@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['timestamp', 'method', 'path', 'ip', 'threatLevel', 'analysis']) &&
             data.timestamp is string &&
             data.method is string &&
             data.path is string &&
             data.ip is string &&
             data.threatLevel in ['low', 'medium', 'high', 'critical'] &&
             data.analysis is string &&
             data.analysis.size() < 5000;
    }

    // Rules
    match /logs/{logId} {
      // Only authenticated admins can read logs (IDS data is sensitive)
      allow read: if isAdmin();
      // Any authenticated user (or system process) can create logs
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      // Logs are immutable once written
      allow update, delete: if false;
    }

    match /stats/current {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
